# ─────────────────────────────────────────────────────────────────────────────
# DiaryNews — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────


# ── AI Summaries (MiniMax) ────────────────────────────────────────────────────
#
# Used to generate article summaries (Portuguese) and YouTube caption summaries
# (Chinese structured format). Without this key the app still works — articles
# and videos are displayed, but no AI summaries are generated.
#
# Get your key at: https://www.minimaxi.com
#
MINIMAX_API_KEY=


# ── YouTube Data API v3 ───────────────────────────────────────────────────────
#
# Required only when adding a new channel by @handle. Once a channel's ID is
# resolved and saved to data/youtube.json, this key is no longer needed for
# fetching videos or captions.
#
# Get your key at: https://console.cloud.google.com → YouTube Data API v3
#
YOUTUBE_API_KEY=


# ── Caption Transcription: Tier 2 — Whisper API (OpenAI) ─────────────────────
#
# Set ENABLE_WHISPER_API=true to use OpenAI's Whisper API as a fallback when
# YouTube captions are unavailable. Requires an OpenAI API key.
# Note: incurs cost per audio minute transcribed.
#
# Get your key at: https://platform.openai.com/api-keys
#
ENABLE_WHISPER_API=false
OPENAI_API_KEY=


# ── Caption Transcription: Tier 3 — Local Whisper ────────────────────────────
#
# Set ENABLE_WHISPER_LOCAL=true to run Whisper locally as a last-resort
# fallback. Requires the openai-whisper package:
#
#   pip install openai-whisper
#
# WHISPER_MODEL controls the model size. Larger models are more accurate but
# slower and use more memory:
#
#   tiny    ~39M params  — fastest, lowest accuracy
#   base    ~74M params  — good balance (default)
#   small   ~244M params — better accuracy
#   medium  ~769M params — high accuracy, slow on CPU
#   large   ~1.5B params — best accuracy, requires GPU
#
ENABLE_WHISPER_LOCAL=false
WHISPER_MODEL=base
